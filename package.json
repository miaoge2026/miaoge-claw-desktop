{
  "name": "easiest-claw-desktop",
  "version": "1.0.10",
  "description": "喵哥Claw Desktop - 强大的AI智能体桌面应用",
  "main": "out/main/index.js",
  "preload": "out/preload/index.js",
  "scripts": {
    "build": "electron-vite build",
    "build:linux": "npm run bundle:openclaw && npm run build && electron-builder --linux",
    "build:win": "npm run bundle:openclaw && npm run build && electron-builder --win",
    "build:mac": "npm run bundle:openclaw && npm run build && electron-builder --mac",
    "dev": "electron-vite dev",
    "bundle:openclaw": "node scripts/bundle-openclaw.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.miaoge.claw.desktop",
    "productName": "喵哥Claw Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/vc_redist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "喵哥Claw Desktop",
      "menuCategory": "喵哥Claw"
    },
    "publish": {
      "provider": "github",
      "owner": "miaoge2026",
      "repo": "miaoge-claw-desktop"
    }
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.0.0",
    "@electron-toolkit/preload": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.8.2",
    "vite": "^6.4.1",
    "winston": "^3.17.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "fs-extra": "^11.3.0",
    "winreg": "^1.2.4"
  }
}
